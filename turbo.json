{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "start": {
      "cache": false
    },
    "lint": {},
    "test": {},
    "typecheck": {},
    "format": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}