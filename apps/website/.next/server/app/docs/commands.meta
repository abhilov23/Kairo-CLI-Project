{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/commands/layout,_N_T_/docs/commands/page,_N_T_/docs/commands"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/commands/__PAGE__",
    "/docs/commands",
    "/docs",
    "/_index",
    "/_head"
  ]
}