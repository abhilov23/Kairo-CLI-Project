{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/providers/layout,_N_T_/docs/providers/page,_N_T_/docs/providers"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/providers/__PAGE__",
    "/docs/providers",
    "/docs",
    "/_index",
    "/_head"
  ]
}