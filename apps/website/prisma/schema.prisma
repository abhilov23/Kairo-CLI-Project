generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── NextAuth v5 Adapter Models ──

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  hashedPassword String?
  accounts      Account[]
  sessions      Session[]
  deviceCodes   DeviceCode[]
  kairoSessions KairoSession[]
  apiKeys       ApiKey[]
  usageLogs     UsageLog[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}


model CliTokenBlocklist {
  id        String   @id @default(cuid())
  jti       String   @unique  // JWT "jti" claim — unique token ID
  userId    String
  expiresAt DateTime           // so we can clean up old rows
  createdAt DateTime @default(now())
}


model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── KairoCLI Custom Models ──

model DeviceCode {
  id           String    @id @default(cuid())
  deviceCode   String    @unique
  userCode     String
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       String    @default("pending")  // pending | authorized | expired
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  authorizedAt DateTime?
}

model KairoSession {
  id         String     @id @default(cuid())
  userId     String
  title      String     // first message in the session
  provider   String     // e.g. "openai", "anthropic"
  model      String     // e.g. "gpt-4o", "claude-sonnet-4"
  tokenCount Int        @default(0)
  workspace  String?    // directory path where session was created
  messages   Json?      // full conversation messages array
  createdAt  DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs  UsageLog[]

  @@index([userId, createdAt])
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  keyHash   String   // bcrypt hash of the API key
  label     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageLog {
  id             String       @id @default(cuid())
  userId         String
  kairoSessionId String?
  tokens         Int
  provider       String
  model          String
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kairoSession   KairoSession? @relation(fields: [kairoSessionId], references: [id], onDelete: SetNull)
}
